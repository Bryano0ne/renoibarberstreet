# ════════════════════════════════════════════════════════════════
# RENOÏ BARBERSTREET — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# ════════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────────
# URL publique de l'app (sans trailing slash)
# En prod : https://renoi-barberstreet.vercel.app  (ou ton domaine custom)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Salons — numéros de téléphone ───────────────────────────────
NEXT_PUBLIC_SALON_ZAD_PHONE=+22667912222
NEXT_PUBLIC_SALON_SAABA_PHONE=+22607952434

# ─── Gérant dashboard ────────────────────────────────────────────
# Mot de passe pour /gerant — change-le en prod !
GERANT_PASSWORD=renoi2026

# ─── Supabase (base de données) ───────────────────────────────────
# Crée un projet sur https://supabase.com
# Settings > API > Project URL & anon key
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Settings > API > service_role key (JAMAIS exposé côté client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── CinetPay (paiements Mobile Money) ───────────────────────────
# Crée un compte sur https://cinetpay.com
# Laisse les valeurs "your_..." pour rester en mode démo
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_site_id
CINETPAY_SECRET_KEY=your_secret_key

# ─── WhatsApp Business API ────────────────────────────────────────
# Meta for Developers > WhatsApp > API Setup
WHATSAPP_API_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ─── Africa's Talking (SMS de confirmation) ───────────────────────
# https://africastalking.com — compte sandbox gratuit disponible
AFRICASTALKING_API_KEY=your_africastalking_key
AFRICASTALKING_USERNAME=sandbox

# ─── NextAuth (si migration vers NextAuth.js v5) ──────────────────
# Génère NEXTAUTH_SECRET avec : openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_generate_with_openssl
